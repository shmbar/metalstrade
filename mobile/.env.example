# Firebase web config (same project as the web CRM). Expo exposes EXPO_PUBLIC_*
# vars to the client bundle. Copy to .env and fill from the web app's .env.local
# (the NEXT_PUBLIC_* values map 1:1 to the EXPO_PUBLIC_* names below).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Base URL of the deployed Next.js app — used as the backend for AI/email/metal-prices
# endpoints (app/api/*). e.g. https://your-crm.vercel.app
EXPO_PUBLIC_API_BASE_URL=

# OpenExchangeRates app id (= web's NEXT_PUBLIC_OPENEXCHANGERATES_APP_ID). Used for
# historical EUR→USD on contract save; unset → getCur falls back to 1.05.
EXPO_PUBLIC_OPENEXCHANGERATES_APP_ID=
